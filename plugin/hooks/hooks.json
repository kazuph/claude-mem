{
  "description": "Claude-mem v2 memory system hooks (Python + SQLite FTS5)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${CLAUDE_PLUGIN_ROOT}/core\" python -m indexer --backfill",
            "timeout": 300
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${CLAUDE_PLUGIN_ROOT}/core\" python -m injector",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${CLAUDE_PLUGIN_ROOT}/core\" python -m hook",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
